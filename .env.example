# WorthIt? configuration boundary
#
# This root file is a reference template. Copy only the relevant variables into
# the environment used by the frontend or trusted server. Never commit values.

# Public browser configuration. CRA exposes every REACT_APP_* value in the
# built JavaScript bundle; these values cannot be secrets.
REACT_APP_API_URL=http://localhost:3001/api
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=

# Current local Express API.
NODE_ENV=development
PORT=3001
APP_ORIGIN=http://localhost:3000
JWT_SECRET=replace-with-a-long-random-development-secret
DATA_FILE=backend/data.json

# Future production server only. Never prefix these with REACT_APP_ and never
# expose them to the browser. The current local JSON-backed MVP does not consume
# the variables below; they document the planned Supabase integration boundary.
DATABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Configure the selected SMS provider in the Supabase dashboard. Keep provider
# secrets in Supabase/your deployment secret store, not in frontend files.
SMS_PROVIDER=
SMS_PROVIDER_ACCOUNT_ID=
SMS_PROVIDER_AUTH_TOKEN=
SMS_PROVIDER_SENDER=

# Local OTP is intentionally fixed at 123456 in non-production code. There is
# no production fallback variable: production must use Supabase Auth + SMS.
